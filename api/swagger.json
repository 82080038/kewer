      "description": "Loan management"
    },
    {
      "name": "Angsuran",
      "description": "Installment management"
    },
    {
      "name": "Family Risk",
      "description": "Family risk assessment"
    },
    {
      "name": "Kas Bon",
      "description": "Cash advance management"
    },
    {
      "name": "Kas Petugas",
