    "language": {
      "ui_language": "Bahasa Indonesia",
      "labels": "Indonesian",
      "messages": "Indonesian",
      "notifications": "Indonesian"
    },
    "formatting": {
      "currency": {
        "symbol": "Rp",
        "format": "Rp1.000.000",
        "thousands_separator": ".",
        "decimal_separator": ",",
        "php_function": "number_format($value, 0, ',', '.')"
      },
      "date": {
        "display_format": "d F Y",
        "example": "16 April 2026",
        "database_format": "Y-m-d",
        "example_db": "2026-04-16",
        "library": "Flatpickr",
        "altFormat": "d F Y"
      },
      "number": {
        "thousands_separator": ".",
        "decimal_separator": ",",
        "example": "1.000,50"
      }
    }
  },
