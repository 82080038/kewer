# Environment Configuration
APP_NAME="Koperasi"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/kewer

# Database
DB_HOST=localhost
DB_NAME=kewer
DB_USER=root
DB_PASS=root

# JWT Configuration
JWT_SECRET=kewer-super-secret-jwt-key-2024-change-in-production
JWT_EXPIRE_HOURS=24
JWT_REFRESH_EXPIRE_DAYS=7

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME=Kewer System
MAIL_FROM_ADDRESS=noreply@kewer.com

# File Upload
UPLOAD_MAX_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# Cache
CACHE_DRIVER=file
CACHE_PREFIX=kewer_

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Security
CSRF_TOKEN_NAME=csrf_token
SESSION_LIFETIME=7200

# Development Quick Login Credentials (ONLY FOR DEVELOPMENT)
DEV_ADMIN_USER=admin
DEV_ADMIN_PASS=admin
DEV_OWNER_USER=owner
DEV_OWNER_PASS=password
DEV_MANAGER_USER=manager1
DEV_MANAGER_PASS=password
DEV_PETUGAS1_USER=petugas1
DEV_PETUGAS1_PASS=password
DEV_PETUGAS2_USER=petugas2
DEV_PETUGAS2_PASS=password
DEV_KARYAWAN1_USER=karyawan1
DEV_KARYAWAN1_PASS=password
DEV_KARYAWAN2_USER=karyawan2
DEV_KARYAWAN2_PASS=password
