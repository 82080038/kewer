# Environment Configuration
# Copy this file to .env and update with your actual values

# Application
APP_NAME="Koperasi"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/kewer

# Database
DB_HOST=localhost
DB_NAME=kewer
DB_USER=root
DB_PASS=root

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE_HOURS=24
JWT_REFRESH_EXPIRE_DAYS=7

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_NAME=Kewer System
MAIL_FROM_ADDRESS=noreply@kewer.com

# File Upload
UPLOAD_MAX_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# Cache
CACHE_DRIVER=file
CACHE_PREFIX=kewer_

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Security
CSRF_TOKEN_NAME=csrf_token
SESSION_LIFETIME=7200

# WhatsApp Notifikasi (Fonnte - https://fonnte.com)
# Daftar di fonnte.com, tambahkan device WA, dapatkan token
WA_ENABLED=false
WA_TOKEN=your-fonnte-device-token-here

# 2FA (Two-Factor Authentication)
# Aktifkan 2FA untuk role bos/manager via halaman /pages/users/settings_2fa.php
# Tidak perlu konfigurasi tambahan — TOTP diimplementasi native (no library)
# Compatible dengan: Google Authenticator, Authy, Microsoft Authenticator

# Cron Job — jalankan tiap pagi jam 06:00
# 0 6 * * * /opt/lampp/bin/php /opt/lampp/htdocs/kewer/cron/run_daily.php >> /opt/lampp/htdocs/kewer/cron/logs/daily.log 2>&1
